{
  "name": "phonemag",
  "private": true,
  "version": "2.0.0",
  "description": "Système de gestion de magasin de téléphones",
  "author": "Votre Nom",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "electron:dev": "electron .",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.phonemag.app",
    "productName": "PhoneMAG",
    "publish": [
      {
        "provider": "github",
        "owner": "Massar-digital",
        "repo": "PhoneMag",
        "releaseType": "draft"
      }
],
    "files": [
      "dist/**/*",
      "main.cjs",
      "preload.cjs",
      "Logo.png"
    ],
    "directories": {
      "output": "dist_electron"
    },
    "extraResources": [
      {
        "from": "build_backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "public/warranty_template.pdf",
        "to": "warranty.pdf"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "Logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "PhoneMAG",
      "include": "build/installer.nsh"
    }
  },
  "dependencies": {
    "@heroicons/react": "^2.0.18",
    "@hookform/resolvers": "^3.3.2",
    "@tanstack/react-query": "^5.14.0",
    "axios": "^1.6.0",
    "clsx": "^2.0.0",
    "electron-updater": "^6.7.3",
    "html2canvas": "^1.4.1",
    "html5-qrcode": "^2.3.8",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "node-machine-id": "^1.1.12",
    "pdf-lib": "^1.17.1",
    "react": "^18.2.0",
    "react-barcode": "^1.6.1",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.48.0",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.20.0",
    "react-to-print": "^3.2.0",
    "recharts": "^2.8.0",
    "yup": "^1.3.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.0.4",
    "@vitest/ui": "^1.0.4",
    "autoprefixer": "^10.4.22",
    "electron": "^39.2.7",
    "electron-builder": "^26.4.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^23.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.0",
    "terser": "^5.44.1",
    "vite": "^5.0.0",
    "vitest": "^1.0.4"
  }
}
